// ========================================
// 测试 Books unit 映射 - 深入排查
// ========================================

config = standalone.GetBooksConfig().toMap();
baseUrl = config.get("baseUrl");
orgId = config.get("organizationId");

// 1. 查看 BX320 这个 Item 在 Books 里的详情（看它的 unit 配置）
info "===== Step 1: Get BX320 item details =====";
itemResp = invokeurl
[
    url: baseUrl + "/items/259067000000277950?organization_id=" + orgId
    type: GET
    connection: "books"
];
if(itemResp.get("code") == 0)
{
    item = itemResp.get("item");
    info "item.name = " + item.get("name");
    info "item.unit = " + item.get("unit");
    info "item.unit_id = " + item.get("unit_id");
    info "item.unit_name = " + item.get("unit_name");
    // 打印所有 key 看有哪些 unit 相关字段
    info "item keys = " + item.keys().toString();
}

// 2. 查看 Books 的 unit groups 列表
info "===== Step 2: Get Books unit groups =====";
unitResp = invokeurl
[
    url: baseUrl + "/settings/units?organization_id=" + orgId
    type: GET
    connection: "books"
];
if(unitResp.get("code") == 0)
{
    unitGroups = unitResp.get("unit_groups");
    if(unitGroups != null)
    {
        for each ug in unitGroups
        {
            info "Unit Group: " + ug.get("name") + " | id: " + ug.get("unit_group_id");
            units = ug.get("units");
            if(units != null)
            {
                for each u in units
                {
                    info "  -> Unit: " + u.get("name") + " | id: " + u.get("unit_id") + " | status: " + u.get("status");
                }
            }
        }
    }
    info "unitResp keys = " + unitResp.keys().toString();
}
else
{
    info "[ERR] Failed to get units: " + unitResp.get("message");
}

// 3. 查看 SO 行项目返回的完整字段
info "===== Step 3: Check SO line item fields =====";
soResp = invokeurl
[
    url: baseUrl + "/salesorders/259067000001720087?organization_id=" + orgId
    type: GET
    connection: "books"
];
if(soResp.get("code") == 0)
{
    firstItem = soResp.get("salesorder").get("line_items").get(0);
    info "First line item keys = " + firstItem.keys().toString();
    info "First line item full = " + firstItem.toString();
}

// 4. 尝试用 unit_id 而不是 unit 字符串来更新
info "===== Step 4: Try update with unit_id =====";
soId = "259067000001720087";

// 先从 step 1 的结果取 unit_id
itemData = itemResp.get("item");
bx320UnitId = itemData.get("unit_id");
info "BX320 unit_id from item = " + bx320UnitId;

// 从 step 2 的 unit groups 中找 "25PKs" 的 unit_id
targetUnitId = null;
unitGroups2 = unitResp.get("unit_groups");
if(unitGroups2 != null)
{
    for each ug2 in unitGroups2
    {
        units2 = ug2.get("units");
        if(units2 != null)
        {
            for each u2 in units2
            {
                uName = u2.get("name");
                if(uName != null && (uName == "25PKs" || uName.contains("25PK")))
                {
                    targetUnitId = u2.get("unit_id");
                    info "Found 25PKs unit_id = " + targetUnitId;
                }
            }
        }
    }
}

if(targetUnitId != null)
{
    testLineItems = List();
    testLi = Map();
    testLi.put("item_id", "259067000000277950");
    testLi.put("name", "BX320");
    testLi.put("quantity", 36);
    testLi.put("rate", 15.38);
    testLi.put("unit_id", targetUnitId);  // 用 unit_id 试试
    testLineItems.add(testLi);

    updateData = Map();
    updateData.put("customer_id", soResp.get("salesorder").get("customer_id"));
    updateData.put("date", soResp.get("salesorder").get("date"));
    updateData.put("line_items", testLineItems);

    info "Update payload: " + updateData.toString();

    updateResp = invokeurl
    [
        url: baseUrl + "/salesorders/" + soId + "?organization_id=" + orgId
        type: PUT
        parameters: updateData.toString()
        connection: "books"
    ];

    info "Update response code: " + updateResp.get("code");
    info "Update response message: " + updateResp.get("message");

    // 验证
    if(updateResp.get("code") == 0)
    {
        verifyResp = invokeurl
        [
            url: baseUrl + "/salesorders/" + soId + "?organization_id=" + orgId
            type: GET
            connection: "books"
        ];
        verifyItems = verifyResp.get("salesorder").get("line_items");
        for each vi in verifyItems
        {
            info "  Item: " + vi.get("name") + " | unit: '" + vi.get("unit") + "' | unit_id: " + vi.get("unit_id");
        }
    }
}
else
{
    info "[WARN] Could not find 25PKs unit_id, skipping unit_id test";
}

return "done";
