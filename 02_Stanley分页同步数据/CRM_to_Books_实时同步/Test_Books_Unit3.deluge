// ========================================
// 测试 Books unit conversion - 第三轮
// ========================================

config = standalone.GetBooksConfig().toMap();
baseUrl = config.get("baseUrl");
orgId = config.get("organizationId");

// 1. 获取 BX320 Item 的 unit_conversions 和 default_sales_unit_conversion_id
info "===== Step 1: Get BX320 unit conversions =====";
itemResp = invokeurl
[
    url: baseUrl + "/items/259067000000277950?organization_id=" + orgId
    type: GET
    connection: "books"
];
if(itemResp.get("code") == 0)
{
    item = itemResp.get("item");
    info "unit_group_id = " + item.get("unit_group_id");
    info "unit_group_name = " + item.get("unit_group_name");
    info "default_sales_unit_conversion_id = " + item.get("default_sales_unit_conversion_id");
    info "default_purchase_unit_conversion_id = " + item.get("default_purchase_unit_conversion_id");

    unitConversions = item.get("unit_conversions");
    if(unitConversions != null)
    {
        info "unit_conversions count = " + unitConversions.size();
        for each uc in unitConversions
        {
            info "  conversion: id=" + uc.get("unit_conversion_id") + " | name=" + uc.get("name") + " | unit=" + uc.get("unit") + " | conversion_rate=" + uc.get("conversion_rate") + " | base_unit=" + uc.get("base_unit") + " | keys=" + uc.keys().toString();
        }
    }
    else
    {
        info "unit_conversions = null";
    }
}

// 2. 尝试获取 unit group 详情
info "===== Step 2: Get unit group details =====";
itemData = itemResp.get("item");
unitGroupId = itemData.get("unit_group_id");
info "unit_group_id = " + unitGroupId;

// 试 /settings/unitgroups/{id}
ugResp = invokeurl
[
    url: baseUrl + "/settings/unitgroups/" + unitGroupId + "?organization_id=" + orgId
    type: GET
    connection: "books"
];
info "unitgroups response code = " + ugResp.get("code");
info "unitgroups response message = " + ugResp.get("message");
if(ugResp.get("code") == 0)
{
    ugData = ugResp.get("unit_group");
    if(ugData != null)
    {
        info "unit_group name = " + ugData.get("name");
        units = ugData.get("units");
        if(units != null)
        {
            for each u in units
            {
                info "  unit: id=" + u.get("unit_id") + " | name=" + u.get("name") + " | keys=" + u.keys().toString();
            }
        }
        conversions = ugData.get("unit_conversions");
        if(conversions != null)
        {
            for each c in conversions
            {
                info "  conversion: id=" + c.get("unit_conversion_id") + " | name=" + c.get("name") + " | keys=" + c.keys().toString();
            }
        }
    }
}
else
{
    // 试另一个 URL 格式
    ugResp2 = invokeurl
    [
        url: baseUrl + "/settings/unit_groups/" + unitGroupId + "?organization_id=" + orgId
        type: GET
        connection: "books"
    ];
    info "unit_groups response code = " + ugResp2.get("code");
    info "unit_groups response message = " + ugResp2.get("message");
    if(ugResp2.get("code") == 0)
    {
        info "unit_groups data = " + ugResp2.toString();
    }
}

// 3. 尝试用 unit_conversion_id 更新 SO 行项目
info "===== Step 3: Update SO line item with unit_conversion_id =====";
soId = "259067000001720087";

// 从 step 1 的 unit_conversions 里找 25PKs
targetConversionId = null;
unitConvs = itemResp.get("item").get("unit_conversions");
if(unitConvs != null)
{
    for each uc2 in unitConvs
    {
        ucName = uc2.get("name");
        ucUnit = uc2.get("unit");
        info "  checking conversion: name=" + ucName + " | unit=" + ucUnit;
        if(ucName != null && (ucName.contains("25PK") || ucUnit != null && ucUnit.contains("25PK")))
        {
            targetConversionId = uc2.get("unit_conversion_id");
            info ">>> Found target: " + targetConversionId;
        }
    }
}

// 也打印 default_sales_unit_conversion_id 作为参考
defaultSalesConvId = itemResp.get("item").get("default_sales_unit_conversion_id");
info "default_sales_unit_conversion_id = " + defaultSalesConvId;

// 无论有没有找到 25PKs，先用 default_sales_unit_conversion_id 试试
if(defaultSalesConvId != null && defaultSalesConvId != "")
{
    info ">> Trying with default_sales_unit_conversion_id: " + defaultSalesConvId;
    testLineItems = List();
    testLi = Map();
    testLi.put("item_id", "259067000000277950");
    testLi.put("name", "BX320");
    testLi.put("quantity", 36);
    testLi.put("rate", 15.38);
    testLi.put("unit_conversion_id", defaultSalesConvId);
    testLineItems.add(testLi);

    updateData = Map();
    updateData.put("customer_id", "259067000000493578");
    updateData.put("date", "2026-07-21");
    updateData.put("line_items", testLineItems);

    info "Update payload: " + updateData.toString();

    updateResp = invokeurl
    [
        url: baseUrl + "/salesorders/" + soId + "?organization_id=" + orgId
        type: PUT
        parameters: updateData.toString()
        connection: "books"
    ];

    info "Update response code: " + updateResp.get("code");
    info "Update response message: " + updateResp.get("message");

    // 验证
    if(updateResp.get("code") == 0)
    {
        verifyResp = invokeurl
        [
            url: baseUrl + "/salesorders/" + soId + "?organization_id=" + orgId
            type: GET
            connection: "books"
        ];
        verifyItems = verifyResp.get("salesorder").get("line_items");
        for each vi in verifyItems
        {
            info "  Item: " + vi.get("name") + " | unit: '" + vi.get("unit") + "' | unit_conversion_id: " + vi.get("unit_conversion_id") + " | conversion_rate: " + vi.get("conversion_rate");
        }
    }
}
else
{
    info "[WARN] default_sales_unit_conversion_id is null, cannot test";
}

return "done";
