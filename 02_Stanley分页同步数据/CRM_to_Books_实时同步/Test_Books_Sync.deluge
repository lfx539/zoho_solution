// ============================================================================
// 快速测试：测试 Books API 连接
// ============================================================================

string test.TestBooksConnection()
{
    result = Map();

    info "测试 Books API 连接...";

    try
    {
        // 获取配置
        config = standalone.GetBooksConfig().toMap();
        baseUrl = config.get("baseUrl");
        orgId = config.get("organizationId");

        // 测试 API 调用：获取组织信息
        response = invokeurl
        [
            url: baseUrl + "/organizations?organization_id=" + orgId
            type: GET
            connection: "books"
        ];

        responseMap = response;

        if(responseMap.get("code") == 0)
        {
            organizations = responseMap.get("organizations");
            info "[OK] Books API 连接成功";
            info "组织数量: " + organizations.size();

            result.put("status", "success");
            result.put("organizationCount", organizations.size());
        }
        else
        {
            errorMsg = responseMap.get("message");
            info "[ERR] Books API 连接失败: " + errorMsg;
            result.put("status", "failed");
            result.put("error", errorMsg);
        }
    }
    catch (e)
    {
        info "[ERR] Books API 连接异常: " + e;
        result.put("status", "failed");
        result.put("error", e.toString());
    }

    return result.toString();
}
